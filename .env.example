# ─────────────────────────────────────────────────────────────────────────────
# FLOW IT — Frontend environment variables (.env.example)
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your values below
# 3. In Vercel: Settings → Environment Variables (add the same keys)
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API ───────────────────────────────────────────────────────────────
# URL of the FlowApi backend — no trailing slash
VITE_API_URL=http://localhost:3000

# ── App identity (white-label) ────────────────────────────────────────────────
# Name shown in the navbar, login page, browser <title>, and OG tags
VITE_APP_NAME=Flow IT

# Short tagline shown in the login hero and meta description
VITE_APP_DESCRIPTION=IT Asset Management Platform

# Public URL of this deployment (used in OG meta tags)
VITE_APP_URL=http://localhost:5173

# App version shown in Settings → About
VITE_APP_VERSION=1.0.0

# Company/vendor name in the login footer copyright line.
# If empty, VITE_APP_NAME is used instead.
VITE_APP_COMPANY_NAME=

# Support email shown on error pages (optional)
VITE_APP_SUPPORT_EMAIL=

# ── Logo & Favicon ────────────────────────────────────────────────────────────
# Leave EMPTY to use the bundled asset at src/images/logo.png
# Set to an HTTPS URL to load a remote logo (e.g. from Vercel Blob or a CDN)
# Example: VITE_APP_LOGO_URL=https://your-cdn.com/logo.png
VITE_APP_LOGO_URL=

# Favicon URL — same rules as logo. Leave empty to use /public/logo.png
VITE_APP_FAVICON_URL=

# Primary accent colour (informational, used in appConfig)
VITE_APP_PRIMARY_COLOR=#0071e3

# ── AI (optional) ─────────────────────────────────────────────────────────────
VITE_OPENROUTER_API_KEY=

# ── Vercel Blob ───────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=
